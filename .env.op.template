
TWILIO_ACCOUNT_SID=op://Family-Call-Center/Twilio/account-sid
TWILIO_AUTH_TOKEN=op://Family-Call-Center/Twilio/auth-token
TWILIO_PHONE_NUMBER=op://Family-Call-Center/Twilio/phone-number

# Public URL where Twilio and the admin browser reach this app (via NPM).
# Must be https, with no trailing slash.
BASE_URL=https://voice.willineaujamz.com

# Data directory inside the container (matches the compose volume mount).
DATA_DIR=/data

# Flask session signing key.
FLASK_SECRET_KEY=op://Family-Call-Center/App/flask-secret-key

# Admin UI login. Prefer ADMIN_PASSWORD_HASH in production (werkzeug scrypt hash);
# if set, it takes precedence over ADMIN_PASSWORD.
ADMIN_USERNAME=op://Family-Call-Center/Admin/username
ADMIN_PASSWORD=op://Family-Call-Center/Admin/password

# Container image reference used by docker-compose.yml (set after publish.sh).
IMAGE=willineau/family-call-center:latest

# Existing Nginx Proxy Manager Docker network name (docker network ls).
NPM_NETWORK=npm_default
