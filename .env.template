# Plain-text environment template (non-1Password users).
# Copy to .env and fill in real values:  cp .env.template .env
#
# For 1Password-managed secrets, use .env.op.template with `op inject` instead.

# Twilio credentials — find these at https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=+15550000000

# Public URL where Twilio can reach this app (https, no trailing slash)
BASE_URL=https://your-public-hostname.example.com

# Absolute path to the data directory (use /data inside Docker)
DATA_DIR=/absolute/path/to/family-call-center-public/data

# Flask session signing key
FLASK_SECRET_KEY=change-me-to-a-random-string

# Admin UI login credentials.
# Prefer ADMIN_PASSWORD_HASH in production. Generate a hash with:
#   python -c "from werkzeug.security import generate_password_hash; print(generate_password_hash('your-password'))"
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-to-a-strong-password
# ADMIN_PASSWORD_HASH=

# Local dev server bind (run.py). Docker uses gunicorn on 0.0.0.0:8080.
HOST=localhost
PORT=8080
